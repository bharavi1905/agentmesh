# OpenAI API key (from platform.openai.com)
OPENAI_API_KEY=sk-...

# Anthropic API key (from console.anthropic.com) — optional
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot credentials
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=...
# Get your chat ID from @userinfobot on Telegram
TELEGRAM_CHAT_ID=...

# Safety mode — set true during testing, false for live alerts
DRY_RUN=true

# Minimum score to trigger a Telegram alert (1-10)
ALERT_SCORE_THRESHOLD=7
